        letter-spacing: 0.05em;
        color: var(--text-light);
        margin-bottom: 0.35rem;
    }

    .meta-value {
        font-weight: 700;
        font-family: monospace;
        font-size: 0.95rem;
    }

    .warning-card {
        padding: 1rem;
        background: #fffbeb;
        border: 1px solid #fcd34d;
        border-radius: 6px;
        margin-top: 1rem;
    }

    .warning-card h4 {
        margin-bottom: 0.5rem;
        color: #92400e;
        font-size: 0.95rem;
    }

    .warning-card p {
        margin: 0;
        color: #b45309;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .logic-box {
        margin-top: 2rem;
        padding: 1.5rem;
        border-left: 4px solid #059669;
        background: #f2f7f7;
    }

    .logic-box h3 { margin-bottom: 0.85rem; }
    .logic-box p, .logic-box li { line-height: 1.7; color: var(--text-light); }
    .logic-box ul { margin: 0.85rem 0 0 1.25rem; }

    .content-article {
        max-width: 900px;
        line-height: 1.8;
    }

    .content-article h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
    .content-article h3 { font-size: 1.2rem; margin: 1.35rem 0 0.6rem; }
    .content-article p { margin-bottom: 1rem; }

    .guidance-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
