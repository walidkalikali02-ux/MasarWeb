    .faq-grid { display: grid; gap: 1rem; }

    .faq-item {
        padding: 1.25rem;
        border: 1px solid #d9e5e7;
        background: #f9fbfb;
    }

    .faq-item h3 { margin-bottom: 0.45rem; font-size: 1.08rem; }
    .faq-item p { margin: 0; color: var(--text-light); }

    .discovery-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
