<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">
<%- include('../partials/head', { pageTitle: pageTitle || title, description: description }) %>
<body>
<!-- 1. Global Layout Components: Header -->
<%- include('../partials/navbar') %>

<style>
    .component-section {
        margin-bottom: 4rem;
        padding: 2rem;
        border: 1px solid var(--border-color);
        background: var(--bg-color);
    }

    .component-label {
        display: inline-block;
        margin-bottom: 1rem;
        padding: 0.35rem 0.75rem;
        border: 1px solid var(--border-color);
        color: var(--text-light);
        font-size: 0.8rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .identity-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .category-tag {
        display: inline-block;
        padding: 0.35rem 0.85rem;
        margin-bottom: 1rem;
        border-radius: 999px;
        background: #059669;
        color: #f5f7f7;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .identity-title {
        font-size: clamp(2rem, 4vw, 3.2rem);
        line-height: 1.15;
        margin-bottom: 1rem;
    }

    .identity-subtitle {
        max-width: 840px;
        margin: 0 auto;
        font-size: 1.15rem;
        color: var(--text-light);
    }

    .authority-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        align-items: stretch;
    }

    .authority-card {
        padding: 1.25rem;
        background: #f7fafb;
        border: 1px solid #d9e5e7;
    }

    .authority-kicker {
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-light);
        margin-bottom: 0.5rem;
    }

    .authority-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .authority-role {
        color: var(--text-light);
        line-height: 1.6;
    }

    .tool-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 2rem;
    }

    .tool-pane {
        padding: 1.5rem;
        border: 1px solid #d9e5e7;
        background: #f9fbfb;
    }

    .tool-pane h2 {
        margin-bottom: 0.5rem;
        font-size: 1.35rem;
    }

    .tool-pane-intro {
        color: var(--text-light);
        margin-bottom: 1.5rem;
        line-height: 1.7;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .form-group small {
        display: block;
        margin-top: 0.35rem;
        color: var(--text-light);
        line-height: 1.5;
        font-size: 0.85rem;
    }

    .form-select,
    .form-input {
        width: 100%;
        border: 1px solid #c7d7da;
        background: #fff;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
    }

    .scope-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .scope-tag {
        padding: 0.35rem 0.75rem;
        background: #e2e8f0;
        border: 1px solid #cbd5e0;
        border-radius: 4px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
        user-select: none;
    }

    .scope-tag:hover {
        background: #cbd5e0;
    }

    .scope-tag.selected {
        background: #059669;
        color: #fff;
        border-color: #059669;
    }

    .scope-input-group {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }

    .scope-input-group input {
        flex: 1;
    }

    .scope-input-group button {
        padding: 0.75rem 1rem;
        background: #059669;
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
    }

    .tool-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .action-btn {
        padding: 0.9rem 1.5rem;
        border: 1px solid #059669;
        background: #059669;
        color: #fff;
        cursor: pointer;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .action-btn.secondary {
        background: transparent;
        color: #059669;
    }

    .result-section {
        margin-bottom: 1.5rem;
    }

    .result-section h3 {
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #059669;
    }

    .output-block {
        background: #1e293b;
        color: #e2e8f0;
        padding: 1rem;
        border-radius: 6px;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
        font-size: 0.85rem;
        line-height: 1.5;
        word-break: break-all;
        position: relative;
        margin-bottom: 0.75rem;
    }

    .output-block .copy-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.35rem 0.75rem;
        background: #059669;
        color: #fff;
        border: none;
        border-radius: 4px;
        font-size: 0.75rem;
        cursor: pointer;
    }

    .json-viewer {
        background: #1e293b;
        color: #e2e8f0;
        padding: 1rem;
        border-radius: 6px;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
        font-size: 0.85rem;
        line-height: 1.6;
        overflow-x: auto;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .json-key { color: #7dd3fc; }
    .json-string { color: #86efac; }
    .json-number { color: #fcd34d; }

    .result-meta {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .meta-card {
        padding: 1rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
    }

    .meta-label {
        font-size: 0.8rem;
