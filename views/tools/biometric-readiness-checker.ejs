    }

    .tool-pane {
        padding: 1.5rem;
        border: 1px solid #d9e5e7;
        background: #f9fbfb;
    }

    .tool-pane h2 {
        margin-bottom: 0.5rem;
        font-size: 1.35rem;
    }

    .tool-pane-intro {
        color: var(--text-light);
        margin-bottom: 1.5rem;
