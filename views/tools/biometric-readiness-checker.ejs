    }

    .tool-input-group small {
        display: block;
        margin-top: 0.35rem;
        color: var(--text-light);
        line-height: 1.5;
    }

    .ua-input,
    .client-hints-select {
        width: 100%;
        border: 1px solid #c7d7da;
        background: #fff;
        padding: 0.9rem 1rem;
        font-size: 0.98rem;
    }

    .ua-input {
        min-height: 132px;
        resize: vertical;
        font-family: monospace;
        line-height: 1.5;
    }

    .toggle-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
