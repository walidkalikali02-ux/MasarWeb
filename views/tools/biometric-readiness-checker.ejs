    }

    .toggle-card {
        display: flex;
        gap: 0.85rem;
        align-items: flex-start;
        padding: 1rem;
        border: 1px solid #c7d7da;
        background: #fff;
    }

    .toggle-card input {
        margin-top: 0.2rem;
        width: 1rem;
        height: 1rem;
    }

    .toggle-card strong {
        display: block;
        margin-bottom: 0.25rem;
    }

    .toggle-card span {
