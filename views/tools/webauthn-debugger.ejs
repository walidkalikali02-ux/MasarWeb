<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">
<%- include('../partials/head', { pageTitle: pageTitle || title, description: description }) %>
<body>
<!-- 1. Global Layout Components: Header -->
<%- include('../partials/navbar') %>

<style>
    .component-section {
        margin-bottom: 4rem;
        padding: 2rem;
        border: 1px solid var(--border-color);
        background: var(--bg-color);
    }

    .component-label {
        display: inline-block;
        margin-bottom: 1rem;
        padding: 0.35rem 0.75rem;
        border: 1px solid var(--border-color);
        color: var(--text-light);
        font-size: 0.8rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .identity-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .category-tag {
        display: inline-block;
        padding: 0.35rem 0.85rem;
        margin-bottom: 1rem;
        border-radius: 999px;
        background: #1a365d;
        color: #f5f7f7;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .identity-title {
        font-size: clamp(2.2rem, 4vw, 3.4rem);
        line-height: 1.15;
        margin-bottom: 1rem;
    }

    .identity-subtitle {
        max-width: 840px;
        margin: 0 auto;
        font-size: 1.15rem;
        color: var(--text-light);
    }

    .authority-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        align-items: stretch;
    }

    .authority-card {
        padding: 1.25rem;
        background: #f7fafb;
        border: 1px solid #d9e5e7;
    }

    .authority-kicker {
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-light);
        margin-bottom: 0.5rem;
    }

    .authority-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .authority-role {
        color: var(--text-light);
        line-height: 1.6;
    }

    .tool-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 2rem;
    }

    .tool-pane {
        padding: 1.5rem;
        border: 1px solid #d9e5e7;
        background: #f9fbfb;
    }

    .tool-pane h2 {
        margin-bottom: 0.5rem;
        font-size: 1.35rem;
    }

    .tool-pane-intro {
        color: var(--text-light);
        margin-bottom: 1.5rem;
        line-height: 1.7;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .form-group small {
        display: block;
        margin-top: 0.35rem;
        color: var(--text-light);
        line-height: 1.5;
        font-size: 0.85rem;
    }

    .form-select,
    .form-input {
        width: 100%;
        border: 1px solid #c7d7da;
        background: #fff;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
    }

    .toggle-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .toggle-card {
        display: flex;
        gap: 0.85rem;
        align-items: flex-start;
        padding: 1rem;
        border: 1px solid #c7d7da;
        background: #fff;
    }

    .toggle-card input {
        margin-top: 0.2rem;
        width: 1rem;
        height: 1rem;
    }

    .toggle-card strong {
        display: block;
        margin-bottom: 0.25rem;
    }

    .toggle-card span {
        color: var(--text-light);
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .tool-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .action-btn {
        padding: 0.9rem 1.5rem;
        border: 1px solid #1a365d;
        background: #1a365d;
        color: #fff;
        cursor: pointer;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .action-btn.secondary {
        background: transparent;
        color: #1a365d;
    }

    .action-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .result-section {
        margin-bottom: 1.5rem;
    }

    .result-section h3 {
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #1a365d;
    }

    .json-viewer {
        background: #1e293b;
        color: #e2e8f0;
        padding: 1rem;
        border-radius: 6px;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
        font-size: 0.85rem;
        line-height: 1.6;
        overflow-x: auto;
        white-space: pre-wrap;
        word-break: break-all;
        max-height: 300px;
        overflow-y: auto;
    }

    .json-key {
        color: #7dd3fc;
    }

    .json-string {
        color: #86efac;
    }

    .json-number {
        color: #fcd34d;
    }

    .json-boolean {
        color: #f472b6;
    }

    .json-null {
        color: #a5b4fc;
    }

    .hex-viewer {
        background: #1e293b;
        color: #94a3b8;
        padding: 1rem;
        border-radius: 6px;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
        font-size: 0.8rem;
        line-height: 1.5;
        overflow-x: auto;
        word-break: break-all;
        max-height: 200px;
        overflow-y: auto;
    }

    .credential-id-display {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 6px;
    }

    .credential-id-display code {
        font-family: monospace;
        font-size: 0.9rem;
        word-break: break-all;
    }

    .copy-btn {
        padding: 0.4rem 0.75rem;
        background: #1a365d;
        color: #fff;
        border: none;
        border-radius: 4px;
        font-size: 0.8rem;
        cursor: pointer;
        white-space: nowrap;
    }

    .error-message {
        padding: 1rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 6px;
        color: #991b1b;
    }

    .info-message {
        padding: 1rem;
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 6px;
        color: #0369a1;
    }

    .logic-box {
        margin-top: 2rem;
        padding: 1.5rem;
        border-left: 4px solid #1a365d;
        background: #f2f7f7;
    }

    .logic-box h3 {
        margin-bottom: 0.85rem;
    }

    .logic-box p,
    .logic-box li {
        line-height: 1.7;
        color: var(--text-light);
    }

    .logic-box ul {
        margin: 0.85rem 0 0 1.25rem;
    }

    .content-article {
        max-width: 900px;
        line-height: 1.8;
    }

    .content-article h2 {
        font-size: 1.8rem;
        margin: 2rem 0 1rem;
    }

    .content-article h3 {
        font-size: 1.2rem;
        margin: 1.35rem 0 0.6rem;
    }

    .content-article p {
        margin-bottom: 1rem;
    }

    .guidance-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
    }

    .guidance-card {
        padding: 1.25rem;
        border: 1px solid #d9e5e7;
        background: #f9fbfb;
    }

    .guidance-card p:last-child {
