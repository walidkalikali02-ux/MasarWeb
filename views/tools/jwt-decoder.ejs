        line-height: 1.15;
        margin-bottom: 1rem;
    }

    .identity-subtitle {
        max-width: 840px;
        margin: 0 auto;
        font-size: 1.15rem;
        color: var(--text-light);
    }

    .authority-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        align-items: stretch;
    }

    .authority-card {
        padding: 1.25rem;
        background: #f7fafb;
        border: 1px solid #d9e5e7;
    }

    .authority-kicker {
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-light);
        margin-bottom: 0.5rem;
    }

    .authority-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .authority-role {
        color: var(--text-light);
        line-height: 1.6;
    }

    .tool-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 2rem;
    }

    .tool-pane {
        padding: 1.5rem;
        border: 1px solid #d9e5e7;
        background: #f9fbfb;
    }

    .tool-pane h2 {
        margin-bottom: 0.5rem;
        font-size: 1.35rem;
    }

    .tool-pane-intro {
        color: var(--text-light);
        margin-bottom: 1.5rem;
        line-height: 1.7;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .form-group small {
        display: block;
        margin-top: 0.35rem;
        color: var(--text-light);
        line-height: 1.5;
