    }

    .category-tag {
        display: inline-block;
        padding: 0.35rem 0.85rem;
        margin-bottom: 1rem;
        border-radius: 999px;
        background: #4f46e5;
        color: #f5f7f7;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .identity-title {
