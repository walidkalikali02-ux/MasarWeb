<style>
    .component-section {
        margin-bottom: 4rem;
        padding: 2rem;
        border: 1px solid var(--border-color);
        background: var(--bg-color);
    }

    .component-label {
        display: inline-block;
        margin-bottom: 1rem;
        padding: 0.35rem 0.75rem;
        border: 1px solid var(--border-color);
        color: var(--text-light);
