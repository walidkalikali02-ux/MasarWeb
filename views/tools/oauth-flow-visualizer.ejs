        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        align-items: stretch;
    }

    .authority-card {
        padding: 1.25rem;
        background: #f7fafb;
        border: 1px solid #d9e5e7;
    }

    .authority-kicker {
        font-size: 0.8rem;
        letter-spacing: 0.08em;
