    }

    .authority-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .authority-role {
        color: var(--text-light);
        line-height: 1.6;
    }

    .tool-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
