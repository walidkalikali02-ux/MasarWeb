        transform: translateY(-2px);
        border-color: #dc2626;
    }

    .discovery-card h3 { margin-bottom: 0.45rem; font-size: 1.05rem; }
    .discovery-card p { margin: 0; color: var(--text-light); line-height: 1.6; }
