    <!-- 4. Core Tool Component -->
    <section class="component-section" id="tool-interface">
        <span class="component-label">Component 4 / Core Tool</span>
        <div class="tool-shell">
            <div class="tool-pane">
                <h2>Token Configuration</h2>
                <p class="tool-pane-intro">Configure the token parameters. The header and payload accept valid JSON. The secret or key is used to sign the token.</p>

                <div class="form-group">
                    <label for="algorithmSelect">Signing Algorithm</label>
                    <select id="algorithmSelect" class="form-select">
                        <option value="HS256">HS256 (HMAC SHA-256)</option>
                        <option value="HS384">HS384 (HMAC SHA-384)</option>
                        <option value="HS512">HS512 (HMAC SHA-512)</option>
                    </select>
                    <small>HMAC algorithms use a shared secret. For production, consider using asymmetric algorithms with RS256.</small>
                </div>

                <div class="form-group">
                    <label for="headerInput">Header JSON</label>
                    <textarea id="headerInput" class="form-textarea">{
  "alg": "HS256",
  "typ": "JWT"
}</textarea>
                    <small>Standard header fields: alg (algorithm) and typ (type). The algorithm field will be updated based on your selection.</small>
                </div>

                <div class="form-group">
                    <label for="payloadInput">Payload JSON</label>
                    <textarea id="payloadInput" class="form-textarea">{
  "sub": "1234567890",
  "name": "Test User",
  "iat": 1516239022,
  "exp": 1516242622
}</textarea>
                    <small>Standard claims: iss, sub, aud, exp, nbf, iat, jti. Add custom claims as needed.</small>
                </div>

                <div class="form-group">
                    <label for="secretInput">Secret Key (for HMAC signing)</label>
                    <input type="text" id="secretInput" class="form-input" placeholder="Enter your secret key">
                    <small>The secret is used to sign the token. Keep it secure and never share it.</small>
                </div>

                <div class="tool-actions">
                    <button type="button" class="action-btn" id="generateBtn">Generate Token</button>
                    <button type="button" class="action-btn secondary" id="verifyBtn">Verify Token</button>
                    <button type="button" class="action-btn secondary" id="clearBtn">Clear</button>
                </div>
            </div>

            <div class="tool-pane">
                <h2>Generated Token</h2>
                <p class="tool-pane-intro">The token is generated entirely in your browser. No data is sent to any server.</p>

