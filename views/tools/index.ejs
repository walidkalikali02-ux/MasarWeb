<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">
<%- include('../partials/head', { pageTitle: title, description: description }) %>
<body>
    <%- include('../partials/navbar') %>

    <main class="main-content">
        <div class="container">
            <h1 class="page-title"><%= title %></h1>
            
            <div class="tools-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; margin-top: 2rem;">
                <!-- Virus Scanner Tool Card -->
                <a href="/tools/virus-scanner" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🛡️
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'فاحص الفيروسات' : 'Virus Scanner' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'افحص الملفات والروابط باستخدام محركات مكافحة فيروسات متعددة.' : 'Scan files and URLs with multiple antivirus engines.' %>
                    </p>
                </a>

                <!-- Absence Deduction Calculator Tool Card -->
                <a href="/tools/absence-deduction" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🗓️
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'حاسبة خصم الغياب' : 'Absence Deduction' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'احسب خصم الغياب وفق معدل يومي = الشهري ÷ 30.' : 'Calculate absence deductions (daily rate = monthly ÷ 30).' %>
                    </p>
                </a>

                <!-- Password Analyzer Tool Card -->
                <a href="/tools/password-analyzer" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🔐
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'تحليل كلمة المرور' : 'Password Analyzer' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'قياس قوة كلمة المرور والوقت المقدر لكسرها.' : 'Measure password strength and estimated crack time.' %>
                    </p>
                </a>

                <!-- Encryption Key Strength Tool Card -->
                <a href="/tools/key-strength" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🔑
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'حاسبة قوة التشفير' : 'Key Strength Calc' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'تقييم أمان مفاتيح التشفير ضد هجمات القوة الغاشمة.' : 'Evaluate encryption key resilience against brute-force attacks.' %>
                    </p>
                </a>

                <!-- Secure Password Generator Tool Card -->
                <a href="/tools/password-generator" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🔒
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'مولد كلمات المرور' : 'Password Generator' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'إنشاء كلمات مرور آمنة وعشوائية مع خيارات تخصيص متقدمة.' : 'Generate secure random passwords with advanced customization options.' %>
                    </p>
                </a>

                <!-- Diceware Passphrase Generator Tool Card -->
                <a href="/tools/diceware-passphrase" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🎲
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'مولد عبارات المرور' : 'Diceware Passphrase' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'إنشاء عبارات مرور سهلة التذكر باستخدام كلمات عشوائية آمنة.' : 'Create memorable passphrases using secure random dictionary words.' %>
                    </p>
                </a>

                <!-- Password Breach Checker Tool Card -->
                <a href="/tools/breach-checker" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🔍
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'فاحص تسريب البيانات' : 'Breach Checker' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'تحقق مما إذا كان بريدك الإلكتروني أو كلمات المرور قد تسربت في خرق بيانات معروف.' : 'Check if your email or passwords have been exposed in known data breaches.' %>
                    </p>
                </a>

                <!-- Hash Identifier Tool Card -->
                <a href="/tools/hash-identifier" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🧬
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'محدد نوع الهاش' : 'Hash Identifier' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'حدد خوارزمية التشفير المستخدمة في سلسلة الهاش بسرعة ودقة.' : 'Identify the cryptographic algorithm used to create a specific hash string.' %>
                    </p>
                </a>

                <!-- 2FA Code Generator Tool Card -->
                <a href="/tools/2fa-generator" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        📱
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'مولد رموز 2FA' : '2FA Generator' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'أنشئ رموز مصادقة ثنائية من مفاتيحك السرية بدون تطبيق هاتف.' : 'Generate 2FA authentication codes from your secret keys without a mobile app.' %>
                    </p>
                </a>

                <!-- Password Expiration Reminder Tool Card -->
                <a href="/tools/password-expiration" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        ⏰
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'تذكير انتهاء كلمة المرور' : 'Password Expiration' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'تتبع تواريخ انتهاء صلاحية كلمات المرور وتلقي تنبيهات قبل القفل.' : 'Track password expiration dates and receive alerts before account lockouts.' %>
                    </p>
                </a>

                <!-- Password Entropy Calculator Tool Card -->
                <a href="/tools/entropy-calculator" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        📊
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'حاسبة انتروبيا كلمة المرور' : 'Entropy Calculator' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'احسب الانتروبيا الرياضية وقوة كلمة المرور ضد هجمات القوة الغاشمة.' : 'Calculate mathematical entropy and password strength against brute-force attacks.' %>
                    </p>
                </a>

                <!-- Bcrypt Cost Factor Calculator Tool Card -->
                <a href="/tools/bcrypt-calculator" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        ⚡
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'حاسبة عامل Bcrypt' : 'Bcrypt Calculator' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'احسب عامل التكلفة المثالي لـ Bcrypt لموازنة الأمان والأداء.' : 'Calculate the optimal bcrypt cost factor to balance security and performance.' %>
                    </p>
                </a>

                <!-- Team Password Vault Tool Card -->
                <a href="/tools/team-password-vault" class="tool-card" style="display: block; text-decoration: none; color: inherit; background: var(--card-bg); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-color); transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="tool-icon" style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-color);">
                        🏢
                    </div>
                    <h2 style="margin-bottom: 0.5rem;"><%= currentLang === 'ar' ? 'خزنة كلمات المرور للفريق' : 'Team Password Vault' %></h2>
                    <p style="color: var(--text-muted);">
                        <%= currentLang === 'ar' ? 'إدارة الوصول الآمن للحسابات المشتركة مع التحكم في الأدوار والتشفير.' : 'Securely manage shared accounts with role-based access control and encryption.' %>
                    </p>
                </a>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
