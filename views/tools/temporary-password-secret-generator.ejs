<script>
    (() => {
        const lengthInput = document.getElementById('secretLength');
        const lengthValue = document.getElementById('secretLengthValue');
        const complexityProfile = document.getElementById('complexityProfile');
        const expirationValue = document.getElementById('expirationValue');
        const expirationUnit = document.getElementById('expirationUnit');
        const accessLimit = document.getElementById('accessLimit');
        const enablePassphrase = document.getElementById('enablePassphrase');
        const passphraseField = document.getElementById('passphraseField');
        const customPassphrase = document.getElementById('customPassphrase');
        const entropyHint = document.getElementById('entropyHint');
        const generateButton = document.getElementById('generateSecret');

        const secretValue = document.getElementById('secretValue');
        const shareLinkValue = document.getElementById('shareLinkValue');
        const expiresAtValue = document.getElementById('expiresAtValue');
        const auditHashValue = document.getElementById('auditHashValue');

        let currentSecretPackage = null;

        const complexityProfiles = {
            balanced: 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789',
            full: 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789!@#$%^&*()-_=+[]{}:,.?',
            restricted: 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789'
        };

        const updateLengthUI = () => {
            const value = Number(lengthInput.value);
            lengthValue.textContent = value;

            if (value >= 28) {
                entropyHint.textContent = 'Very high entropy preset';
            } else if (value >= 20) {
                entropyHint.textContent = 'High entropy preset';
            } else {
                entropyHint.textContent = 'Standard temporary secret preset';
            }
        };

        const getTtlMilliseconds = () => {
            const amount = Math.max(1, Number(expirationValue.value) || 1);
            const unit = expirationUnit.value;
            if (unit === 'minutes') return amount * 60 * 1000;
            if (unit === 'hours') return amount * 60 * 60 * 1000;
            return amount * 24 * 60 * 60 * 1000;
        };

        const randomIndex = (max) => {
            const limit = Math.floor(256 / max) * max;
            const bytes = new Uint8Array(1);

            while (true) {
                window.crypto.getRandomValues(bytes);
                if (bytes[0] < limit) {
                    return bytes[0] % max;
                }
            }
        };

        const generateSecretString = () => {
            const alphabet = complexityProfiles[complexityProfile.value] || complexityProfiles.full;
            const length = Math.max(12, Number(lengthInput.value) || 20);
            let output = '';

            for (let i = 0; i < length; i += 1) {
                output += alphabet[randomIndex(alphabet.length)];
            }

            return output;
        };

        const toHex = (buffer) => Array.from(new Uint8Array(buffer))
            .map((value) => value.toString(16).padStart(2, '0'))
            .join('');

        const digestText = async (value) => {
            const encoded = new TextEncoder().encode(value);
            return window.crypto.subtle.digest('SHA-256', encoded);
        };

        const deriveSecretPackage = async () => {
            const secret = generateSecretString();
            const issuedAt = new Date();
            const ttlMs = getTtlMilliseconds();
            const expiresAt = new Date(issuedAt.getTime() + ttlMs);
            const passphraseState = enablePassphrase.checked
                ? (customPassphrase.value.trim() || 'required-without-inline-value')
                : 'none';

            const metadataSignature = [
                secret,
                complexityProfile.value,
                ttlMs,
                accessLimit.value,
                passphraseState,
                issuedAt.toISOString()
            ].join('|');

            const fullHash = toHex(await digestText(metadataSignature));
            const linkToken = fullHash.slice(0, 24);

            return {
                secret,
                issuedAt,
                link: `${window.location.origin}/vault/temp/${linkToken}`,
                expiresAt: expiresAt.toISOString(),
                auditHash: `${fullHash.slice(0, 12)}-${fullHash.slice(12, 24)}-${fullHash.slice(24, 36)}`,
                fullHash
            };
        };

        const renderSecretPackage = (payload) => {
            secretValue.textContent = payload.secret;
            shareLinkValue.textContent = payload.link;
            expiresAtValue.textContent = new Date(payload.expiresAt).toLocaleString(undefined, {
                year: 'numeric',
                month: 'short',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
            auditHashValue.textContent = payload.auditHash;
        };

        const refreshDerivedOutputs = async () => {
            if (!currentSecretPackage) {
                return;
            }

            const ttlMs = getTtlMilliseconds();
            const expiresAt = new Date(currentSecretPackage.issuedAt.getTime() + ttlMs);
            const passphraseState = enablePassphrase.checked
                ? (customPassphrase.value.trim() || 'required-without-inline-value')
                : 'none';

            const signature = [
                currentSecretPackage.secret,
                complexityProfile.value,
                ttlMs,
                accessLimit.value,
                passphraseState,
                currentSecretPackage.issuedAt.toISOString()
            ].join('|');

            const fullHash = toHex(await digestText(signature));
            currentSecretPackage = {
                ...currentSecretPackage,
                expiresAt,
                link: `${window.location.origin}/vault/temp/${fullHash.slice(0, 24)}`,
                auditHash: `${fullHash.slice(0, 12)}-${fullHash.slice(12, 24)}-${fullHash.slice(24, 36)}`
            };
            renderSecretPackage({
                secret: currentSecretPackage.secret,
                link: currentSecretPackage.link,
                expiresAt: currentSecretPackage.expiresAt.toISOString(),
                auditHash: currentSecretPackage.auditHash
            });
        };

        const handleGenerate = async () => {
            const generated = await deriveSecretPackage();
            currentSecretPackage = {
                secret: generated.secret,
                issuedAt: generated.issuedAt,
                expiresAt: new Date(generated.expiresAt),
                link: generated.link,
                auditHash: generated.auditHash
            };
            renderSecretPackage(generated);
        };

        lengthInput.addEventListener('input', updateLengthUI);
        lengthInput.addEventListener('change', handleGenerate);
        complexityProfile.addEventListener('change', handleGenerate);
        expirationValue.addEventListener('input', refreshDerivedOutputs);
        expirationUnit.addEventListener('change', refreshDerivedOutputs);
        accessLimit.addEventListener('input', refreshDerivedOutputs);
        enablePassphrase.addEventListener('change', () => {
            passphraseField.hidden = !enablePassphrase.checked;
            refreshDerivedOutputs();
        });
        customPassphrase.addEventListener('input', refreshDerivedOutputs);
        generateButton.addEventListener('click', handleGenerate);

        updateLengthUI();
        handleGenerate();
    })();
</script>

</main>
<%- include('../partials/footer') %>
</body>
</html>
