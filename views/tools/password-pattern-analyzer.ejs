<script>
    (() => {
        const passwordInput = document.getElementById('passwordInput');
        const keyboardWalkToggle = document.getElementById('keyboardWalkToggle');
        const dictionaryToggle = document.getElementById('dictionaryToggle');
        const leetToggle = document.getElementById('leetToggle');

        const complexityScore = document.getElementById('complexityScore');
        const detectedSequences = document.getElementById('detectedSequences');
        const entropyBits = document.getElementById('entropyBits');
        const crackEstimate = document.getElementById('crackEstimate');
        const lengthChip = document.getElementById('lengthChip');
        const charsetChip = document.getElementById('charsetChip');

        const keyboardRows = [
            '1234567890',
            'qwertyuiop',
            'asdfghjkl',
            'zxcvbnm'
        ];

        const commonWords = [
            'password', 'welcome', 'admin', 'letmein', 'secret', 'dragon', 'login',
            'summer', 'winter', 'spring', 'autumn', 'company', 'manager', 'secure',
            'qwerty', 'hello', 'service', 'default'
        ];

        const substitutions = {
            '0': 'o',
            '1': 'i',
            '!': 'i',
            '3': 'e',
            '4': 'a',
            '@': 'a',
            '$': 's',
            '5': 's',
            '7': 't'
        };

        const humanizeDuration = (seconds) => {
            if (seconds < 1) return 'Less than one second';
            if (seconds < 60) return `${Math.round(seconds)} seconds`;
            if (seconds < 3600) return `${Math.round(seconds / 60)} minutes`;
            if (seconds < 86400) return `${Math.round(seconds / 3600)} hours`;
            if (seconds < 31536000) return `${Math.round(seconds / 86400)} days`;
            if (seconds < 3153600000) return `${Math.round(seconds / 31536000)} years`;
            return 'Centuries at current pattern-guessing rates';
        };

        const detectAlphabetSize = (value) => {
            let size = 0;
            if (/[a-z]/.test(value)) size += 26;
            if (/[A-Z]/.test(value)) size += 26;
            if (/[0-9]/.test(value)) size += 10;
            if (/[^A-Za-z0-9]/.test(value)) size += 33;
            return size || 1;
        };

        const findSequentialRuns = (value) => {
            const found = [];
            const lower = value.toLowerCase();

            for (let index = 0; index < lower.length - 2; index += 1) {
                let chunk = lower[index];
                let ascending = true;
                let descending = true;

                for (let cursor = index + 1; cursor < lower.length; cursor += 1) {
                    const previous = lower.charCodeAt(cursor - 1);
                    const current = lower.charCodeAt(cursor);

                    ascending = ascending && current === previous + 1;
                    descending = descending && current === previous - 1;

                    if (!ascending && !descending) {
                        break;
                    }

                    chunk += lower[cursor];
                    if (chunk.length >= 3) {
                        found.push(chunk);
                    }
                }
            }

            return Array.from(new Set(found));
        };

        const findKeyboardWalks = (value) => {
            const lower = value.toLowerCase();
            const matches = [];

            keyboardRows.forEach((row) => {
                const reversed = row.split('').reverse().join('');
                for (let start = 0; start < row.length - 2; start += 1) {
                    for (let size = 3; size <= row.length - start; size += 1) {
                        const fragment = row.slice(start, start + size);
                        const reverseFragment = reversed.slice(row.length - start - size, row.length - start);

                        if (lower.includes(fragment)) {
                            matches.push(fragment);
                        }
                        if (lower.includes(reverseFragment)) {
                            matches.push(reverseFragment);
                        }
                    }
                }
            });

            return Array.from(new Set(matches));
        };

        const normalizeLeet = (value) => value
            .toLowerCase()
            .split('')
            .map((char) => substitutions[char] || char)
            .join('');

        const detectDictionaryMatches = (value) => {
            const lower = value.toLowerCase();
            return commonWords.filter((word) => lower.includes(word));
        };

        const detectLeetMatches = (value) => {
            const normalized = normalizeLeet(value);
            return commonWords.filter((word) => normalized.includes(word));
        };

        const renderDetected = (items) => {
            const values = items.length
                ? items
                : ['No obvious sequence, walk, or matched pattern detected.'];

            detectedSequences.replaceChildren(
                ...values.map((item) => {
                    const node = document.createElement('div');
                    node.className = 'detected-item';
                    node.textContent = item;
                    return node;
                })
            );
        };

        const analyzePassword = () => {
            const value = passwordInput.value || '';
            lengthChip.textContent = `Length: ${value.length}`;

            const alphabetSize = detectAlphabetSize(value);
            charsetChip.textContent = alphabetSize <= 10
                ? 'Alphabet: minimal'
                : alphabetSize <= 52
                    ? 'Alphabet: mixed'
                    : 'Alphabet: broad';

            if (!value) {
                complexityScore.textContent = '0';
                entropyBits.textContent = '0 bits';
                crackEstimate.textContent = 'Not available until input is analyzed.';
                renderDetected([]);
                return;
            }

            const findings = [];
            let penalty = 0;

            const sequentialRuns = findSequentialRuns(value);
            if (sequentialRuns.length) {
                findings.push(...sequentialRuns.map((run) => `Sequence detected: ${run}`));
                penalty += sequentialRuns.length * 8;
            }

            if (keyboardWalkToggle.checked) {
                const keyboardWalks = findKeyboardWalks(value);
                if (keyboardWalks.length) {
                    findings.push(...keyboardWalks.map((walk) => `Keyboard walk detected: ${walk}`));
                    penalty += keyboardWalks.length * 12;
                }
            }

            if (dictionaryToggle.checked) {
                const dictionaryMatches = detectDictionaryMatches(value);
                if (dictionaryMatches.length) {
                    findings.push(...dictionaryMatches.map((word) => `Dictionary fragment detected: ${word}`));
                    penalty += dictionaryMatches.length * 10;
                }
            }

            if (leetToggle.checked) {
                const leetMatches = detectLeetMatches(value);
                if (leetMatches.length) {
                    findings.push(...leetMatches.map((word) => `L33t-style substitution detected: ${word}`));
                    penalty += leetMatches.length * 6;
                }
            }

            const repeatedChunk = value.match(/(.)\1{2,}/g);
            if (repeatedChunk) {
                findings.push(...repeatedChunk.map((chunk) => `Repeated character group: ${chunk}`));
                penalty += repeatedChunk.length * 7;
            }

            const structureMatch = value.match(/^[A-Z]?[a-z]+[0-9]+[^A-Za-z0-9]?$/);
            if (structureMatch) {
                findings.push('Common word + digits + optional symbol structure');
                penalty += 14;
            }

            const rawEntropy = value.length * Math.log2(alphabetSize);
            const effectiveEntropy = Math.max(4, rawEntropy - penalty);
            const score = Math.max(0, Math.min(100, Math.round((effectiveEntropy / 80) * 100)));
            const guesses = Math.pow(2, effectiveEntropy);
            const secondsToCrack = guesses / 100000000;

            complexityScore.textContent = String(score);
            entropyBits.textContent = `${effectiveEntropy.toFixed(1)} bits`;
            crackEstimate.textContent = humanizeDuration(secondsToCrack);
            renderDetected(findings);
        };

        passwordInput.addEventListener('input', analyzePassword);
        keyboardWalkToggle.addEventListener('change', analyzePassword);
        dictionaryToggle.addEventListener('change', analyzePassword);
        leetToggle.addEventListener('change', analyzePassword);

        analyzePassword();
    })();
</script>

</main>
<%- include('../partials/footer') %>
</body>
</html>
