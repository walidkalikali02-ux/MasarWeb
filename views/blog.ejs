<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">
<%- include('partials/head', { pageTitle: t.blog_title || 'Blog' }) %>
<body class="blog-page">
    <%- include('partials/navbar') %>

    <main class="main-content">
        <div class="container">
            
            <header class="page-header">
                <h1 class="page-title"><%= t.blog_title || 'Blog' %></h1>
            </header>
            
            <section class="blog-grid" aria-label="Blog Articles">
                <% articles.forEach(function(article) { %>
                    <article class="blog-card">
                        <div class="blog-card-content">
                            <time class="blog-date" datetime="<%= article.date %>"><%= article.date %></time>
                            <h2>
                                <a href="/blog/<%= article.slug %>"><%= article.title %></a>
                            </h2>
                            <p><%= article.excerpt %></p>
                            <a href="/blog/<%= article.slug %>" class="read-more">
                                <%= t.read_more || 'Read More' %>
                            </a>
                        </div>
                    </article>
                <% }); %>
            </section>

        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>