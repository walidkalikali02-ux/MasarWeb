<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">
<%- include('partials/head') %>
<body class="homepage">
    <%- include('partials/navbar') %>

    <main class="container">
        
        <!-- Hero Section -->
        <header class="hero minimal-arabic-hero" role="banner">
            <div class="minimal-accent-wrapper" aria-hidden="true">
                <svg class="minimal-star" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" fill="none" stroke-width="0.3">
                    <rect x="20" y="20" width="60" height="60" transform="rotate(0 50 50)" />
                    <rect x="20" y="20" width="60" height="60" transform="rotate(45 50 50)" />
                    <circle cx="50" cy="50" r="10" />
                </svg>
            </div>
            <div class="hero-content animate-on-scroll">
                <p class="hero-eyebrow-minimal">مسار ويب</p>
                <h1 class="hero-headline"><%= t.title %></h1>
                <p class="hero-subhead"><%= t.tagline %></p>
                <div class="hero-cta-group">
                    <a href="#search" class="btn-minimal-primary">
                        <span>ابدأ التصفح الآن</span>
                    </a>
                </div>
            </div>
        </header>

        <!-- Search Section -->
        <section id="search" class="search-wrap" aria-label="بحث المواقع">
            <div class="search-container animate-on-scroll">
                <div class="search-hint">
                    <svg class="hint-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                    </svg>
                    <span>أدخل عنوان الموقع للتصفح</span>
                </div>
                <form action="/browse" method="POST" class="search-form-pill" id="search-form">
                    <div class="search-field-pill">
                        <input 
                            type="url" 
                            name="url" 
                            id="url-input"
                            class="search-input-pill"
                            placeholder="<%= t.placeholder %>"
                            value="<%= currentUrl || '' %>"
                            autocomplete="off"
                            required
                            aria-label="عنوان الموقع"
                            inputmode="url"
                        >
                        <button type="submit" class="search-btn-pill" aria-label="<%= t.browse %>">
                            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M5 12h14"/>
                                <path d="m12 5 7 7-7 7"/>
                            </svg>
                            <svg class="btn-loader" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                                <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
                                <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                            </svg>
                        </button>
                    </div>
                </form>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-clean" role="alert" aria-live="polite">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 8v4M12 16h.01"/>
                        </svg>
                        <span><%= error %></span>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="features-section" aria-labelledby="features-title">
            <h2 id="features-title" class="features-title animate-on-scroll"><%= t.features_title %></h2>
            <div class="features-list stagger-children">
                
                <article class="feature-card-h">
                    <div class="feature-icon-h" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <div class="feature-content-h">
                        <h3><%= t.privacy_title %></h3>
                        <p><%= t.privacy_desc %></p>
                    </div>
                </article>

                <article class="feature-card-h">
                    <div class="feature-icon-h" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                        </svg>
                    </div>
                    <div class="feature-content-h">
                        <h3><%= t.speed_title %></h3>
                        <p><%= t.speed_desc %></p>
                    </div>
                </article>

                <article class="feature-card-h">
                    <div class="feature-icon-h" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <div class="feature-content-h">
                        <h3><%= t.protection_title %></h3>
                        <p><%= t.protection_desc %></p>
                    </div>
                </article>

                <article class="feature-card-h">
                    <div class="feature-icon-h" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                            <path d="M12 18h.01"/>
                        </svg>
                    </div>
                    <div class="feature-content-h">
                        <h3><%= t.devices_title %></h3>
                        <p><%= t.devices_desc %></p>
                    </div>
                </article>

                <article class="feature-card-h">
                    <div class="feature-icon-h" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <path d="m9 12 2 2 4-4"/>
                        </svg>
                    </div>
                    <div class="feature-content-h">
                        <h3><%= t.encryption_title %></h3>
                        <p><%= t.encryption_desc %></p>
                    </div>
                </article>

                <article class="feature-card-h">
                    <div class="feature-icon-h" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                        </svg>
                    </div>
                    <div class="feature-content-h">
                        <h3><%= t.support_title %></h3>
                        <p><%= t.support_desc %></p>
                    </div>
                </article>

            </div>
        </section>

        <!-- How It Works Section -->
        <section class="how-it-works" aria-labelledby="how-title">
            <h2 id="how-title" class="how-title animate-on-scroll"><%= t.how_it_works_title %></h2>
            <div class="timeline stagger-children">
                
                <div class="timeline-item">
                    <div class="timeline-marker" aria-hidden="true">
                        <div class="timeline-dot"></div>
                        <div class="timeline-line"></div>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/>
                                <path d="m21 21-4.35-4.35"/>
                            </svg>
                        </div>
                        <h3>1</h3>
                        <p><%= t.step1 %></p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-marker" aria-hidden="true">
                        <div class="timeline-dot"></div>
                        <div class="timeline-line"></div>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                        </div>
                        <h3>2</h3>
                        <p><%= t.step2 %></p>
                    </div>
                </div>

                <div class="timeline-item timeline-item-last">
                    <div class="timeline-marker" aria-hidden="true">
                        <div class="timeline-dot"></div>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                <path d="m9 11 3 3L22 4"/>
                            </svg>
                        </div>
                        <h3>3</h3>
                        <p><%= t.step3 %></p>
                    </div>
                </div>

            </div>
        </section>

        <!-- Why Use Section -->
        <% if (t.why_use_title) { %>
        <section class="info-section why-use" aria-labelledby="why-title">
            <h2 id="why-title" class="animate-on-scroll"><%= t.why_use_title %></h2>
            <div class="info-grid stagger-children">
                <% t.why_use_items.forEach(function(item) { %>
                    <article class="info-card">
                        <h3><%= item.title %></h3>
                        <p><%= item.desc %></p>
                    </article>
                <% }); %>
            </div>
        </section>
        <% } %>

        <!-- How Proxy Works Section -->
        <% if (t.how_proxy_works_title) { %>
        <section class="info-section how-proxy-works" aria-labelledby="proxy-title">
            <h2 id="proxy-title" class="animate-on-scroll"><%= t.how_proxy_works_title %></h2>
            <div class="text-content">
                <p><%= t.how_proxy_works_desc %></p>
            </div>
        </section>
        <% } %>

        <!-- Security & Privacy Section -->
        <% if (t.security_privacy_title) { %>
        <section class="info-section security-privacy" aria-labelledby="security-title">
            <h2 id="security-title" class="animate-on-scroll"><%= t.security_privacy_title %></h2>
            <div class="security-grid stagger-children">
                <% t.security_privacy_items.forEach(function(item) { %>
                    <article class="security-card">
                        <div class="security-icon" aria-hidden="true"><%= item.icon %></div>
                        <h3><%= item.title %></h3>
                        <p><%= item.desc %></p>
                    </article>
                <% }); %>
            </div>
        </section>
        <% } %>

        <!-- Use Cases Section -->
        <% if (t.use_cases_title) { %>
        <section class="info-section use-cases" aria-labelledby="usecases-title">
            <h2 id="usecases-title" class="animate-on-scroll"><%= t.use_cases_title %></h2>
            <ul class="use-cases-list stagger-children">
                <% t.use_cases_items.forEach(function(item) { %>
                    <li>
                        <span class="check-icon" aria-hidden="true">✓</span>
                        <span><%= item %></span>
                    </li>
                <% }); %>
            </ul>
        </section>
        <% } %>

        <!-- FAQ Section -->
        <% if (t.faq_title) { %>
        <section class="info-section faq-section" aria-labelledby="faq-title">
            <h2 id="faq-title" class="animate-on-scroll"><%= t.faq_title %></h2>
            <div class="faq-grid stagger-children">
                <% t.faq_items.forEach(function(item) { %>
                    <article class="faq-item">
                        <h3 class="faq-question"><%= item.q %></h3>
                        <p class="faq-answer"><%= item.a %></p>
                    </article>
                <% }); %>
            </div>
        </section>
        <% } %>

        <!-- Popular Sites Section -->
        <section class="popular-sites" aria-labelledby="sites-title">
            <h2 id="sites-title" class="animate-on-scroll"><%= t.popular_sites_title %></h2>
            <div class="sites-grid stagger-children">
                <% if (t.popular_sites && t.popular_sites.length > 0) { %>
                    <% t.popular_sites.forEach(function(site) { %>
                        <a href="#" onclick="event.preventDefault(); document.getElementById('url-input').value='<%= site.url %>'; document.getElementById('search-form').submit();" class="site-btn">
                            <span aria-hidden="true"><%= site.icon %></span> 
                            <span><%= site.name %></span>
                        </a>
                    <% }); %>
                <% } %>
            </div>
        </section>
        
    </main>

    <%- include('partials/footer') %>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-focus search input
            var input = document.getElementById('url-input');
            var form = document.getElementById('search-form');
            var btn = form ? form.querySelector('.search-btn-pill') : null;
            
            if (input) input.focus();
            
            // Form submission handling
            if (form) {
                form.addEventListener('submit', function(e) {
                    if (!input.value.trim()) {
                        e.preventDefault();
                        input.focus();
                        return;
                    }
                    form.classList.add('submitting');
                    if (btn) btn.classList.add('loading');
                });
            }
            
            // Popular sites button handling
            var popularBtns = document.querySelectorAll('.site-btn');
            popularBtns.forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    var form = document.getElementById('search-form');
                    if (form) {
                        form.classList.add('submitting');
                        var submitBtn = form.querySelector('.search-btn-pill');
                        if (submitBtn) submitBtn.classList.add('loading');
                    }
                });
            });
            
            // Scroll animation observer
            var animatedElements = document.querySelectorAll('.animate-on-scroll, .stagger-children');
            
            if ('IntersectionObserver' in window) {
                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('visible');
                            observer.unobserve(entry.target);
                        }
                    });
                }, {
                    threshold: 0.1,
                    rootMargin: '0px 0px -50px 0px'
                });
                
                animatedElements.forEach(function(el) {
                    observer.observe(el);
                });
            } else {
                // Fallback for browsers without IntersectionObserver
                animatedElements.forEach(function(el) {
                    el.classList.add('visible');
                });
            }
            
            // Smooth scroll for anchor links
            document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
                anchor.addEventListener('click', function(e) {
                    var targetId = this.getAttribute('href');
                    if (targetId === '#') return;
                    
                    var targetElement = document.querySelector(targetId);
                    if (targetElement) {
                        e.preventDefault();
                        targetElement.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });
        });
    </script>
</body>
</html>
