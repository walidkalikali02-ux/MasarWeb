<%
    const offers = Array.isArray(affiliateOffers) ? affiliateOffers : [];
    const context = typeof affiliateContext !== 'undefined' ? affiliateContext : 'general';
    const hasConfiguredAffiliateLinks = offers.some((offer) => offer.configured);
    const isArabic = currentLang === 'ar';
    const blockTitle = context === 'tools'
        ? (isArabic ? 'عروض نوصي بها لمستخدمي الأدوات' : 'Recommended Offers For Tool Users')
        : context === 'blog'
            ? (isArabic ? 'خدمات مرتبطة بالمقال' : 'Services Related To This Article')
            : (isArabic ? 'خدمات موصى بها' : 'Recommended Services');
    const blockIntro = isArabic
        ? 'هذه العروض مرتبطة بموضوع الخصوصية، كلمات المرور، وبيئات التطوير. استبدل الروابط الحالية بروابطك التابعة الفعلية عبر متغيرات البيئة.'
        : 'These offers are related to privacy, password security, and development workflows. Replace the current links with your real affiliate links through environment variables.';
    const disclosure = isArabic
        ? 'إفصاح: قد نحصل على عمولة إذا اشتريت عبر بعض الروابط.'
        : 'Disclosure: we may earn a commission if you purchase through some links.';
    const statusLabel = hasConfiguredAffiliateLinks
        ? (isArabic ? 'روابط تابعة مفعلة' : 'Affiliate Links Active')
        : (isArabic ? 'روابط افتراضية تحتاج استبدال' : 'Default Links Need Replacement');
%>
<section class="affiliate-section affiliate-section-<%= context %>">
    <div class="affiliate-section-head">
        <div>
            <p class="affiliate-kicker"><%= disclosure %></p>
            <h2><%= blockTitle %></h2>
            <p class="affiliate-intro"><%= blockIntro %></p>
        </div>
        <span class="affiliate-status"><%= statusLabel %></span>
    </div>

    <div class="affiliate-grid">
        <% offers.forEach(function(offer) { %>
            <article class="affiliate-card">
                <div class="affiliate-card-top">
                    <span class="affiliate-emoji" aria-hidden="true"><%= offer.emoji %></span>
                    <div>
                        <p class="affiliate-brand"><%= offer.brand %></p>
                        <p class="affiliate-category"><%= offer.category %></p>
                    </div>
                </div>
                <p class="affiliate-copy"><%= offer.pitch %></p>
                <a href="<%= offer.url %>" class="affiliate-link" target="_blank" rel="nofollow sponsored noopener noreferrer">
                    <span><%= offer.cta %></span>
                    <span aria-hidden="true">↗</span>
                </a>
            </article>
        <% }); %>
    </div>
</section>
