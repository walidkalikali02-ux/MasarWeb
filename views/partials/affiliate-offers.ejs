<%
    const offers = Array.isArray(affiliateOffers) ? affiliateOffers : [];
    const context = typeof affiliateContext !== 'undefined' ? affiliateContext : 'general';
    const hasConfiguredAffiliateLinks = offers.some((offer) => offer.configured);
    const blockTitle = context === 'tools'
        ? 'عروض نوصي بها لمستخدمي الأدوات'
        : context === 'blog'
            ? 'خدمات مرتبطة بالمقال'
            : 'خدمات موصى بها';
    const blockIntro = 'هذه العروض مرتبطة بموضوع الخصوصية، كلمات المرور، وبيئات التطوير. استبدل الروابط الحالية بروابطك التابعة الفعلية عبر متغيرات البيئة.';
    const disclosure = 'إفصاح: قد نحصل على عمولة إذا اشتريت عبر بعض الروابط.';
    const statusLabel = hasConfiguredAffiliateLinks ? 'روابط تابعة مفعلة' : 'روابط افتراضية تحتاج استبدال';
%>
<section class="affiliate-section affiliate-section-<%= context %>">
    <div class="affiliate-section-head">
        <div>
            <p class="affiliate-kicker"><%= disclosure %></p>
            <h2><%= blockTitle %></h2>
            <p class="affiliate-intro"><%= blockIntro %></p>
        </div>
        <span class="affiliate-status"><%= statusLabel %></span>
    </div>

    <div class="affiliate-grid">
        <% offers.forEach(function(offer) { %>
            <article class="affiliate-card">
                <div class="affiliate-card-top">
                    <span class="affiliate-emoji" aria-hidden="true"><%= offer.emoji %></span>
                    <div>
                        <p class="affiliate-brand"><%= offer.brand %></p>
                        <p class="affiliate-category"><%= offer.category %></p>
                    </div>
                </div>
                <p class="affiliate-copy"><%= offer.pitch %></p>
                <a href="<%= offer.url %>" class="affiliate-link" target="_blank" rel="nofollow sponsored noopener noreferrer">
                    <span><%= offer.cta %></span>
                    <span aria-hidden="true">↗</span>
                </a>
            </article>
        <% }); %>
    </div>
</section>
