<%
    const buildLangHref = (langCode) => (
        langCode === 'ar' ? currentUrl : `${currentUrl}?lang=${langCode}`
    );
%>
<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-logo">
            <img src="/static/images/logo.svg" alt="<%= t.title %>" class="logo-img">
        </a>
        
        <div class="nav-links">
            <a href="/" class="<%= currentUrl === '/' ? 'active' : '' %>"><%= t.nav_home %></a>
            <a href="/about" class="<%= currentUrl === '/about' ? 'active' : '' %>"><%= t.nav_about || (currentLang === 'ar' ? 'من نحن' : 'About') %></a>
            <a href="/blog" class="<%= currentUrl && currentUrl.startsWith('/blog') ? 'active' : '' %>"><%= t.nav_blog || 'Blog' %></a>
            <a href="/tools" class="<%= currentUrl && currentUrl.startsWith('/tools') ? 'active' : '' %>"><%= t.nav_tools || (currentLang === 'ar' ? 'أدوات' : 'Tools') %></a>
            <a href="/support" class="<%= currentUrl === '/support' ? 'active' : '' %>"><%= t.nav_support %></a>
            <a href="/terms" class="<%= currentUrl === '/terms' ? 'active' : '' %>"><%= t.nav_terms %></a>
            <a href="/privacy" class="<%= currentUrl === '/privacy' ? 'active' : '' %>"><%= t.nav_privacy %></a>
        </div>

        <div class="nav-search-placeholder" aria-hidden="true">
            <span><%= currentLang === 'ar' ? 'ابحث في الأدوات قريباً' : 'Search tools soon' %></span>
        </div>

        <div class="lang-dropdown">
            <button class="lang-btn-toggle" id="langBtn" aria-expanded="false" aria-label="Select Language">
                <i class="fas fa-globe"></i> 
                <span><%= currentLang.toUpperCase() %></span>
            </button>
            <div class="lang-menu" id="langMenu">
                <a href="<%= buildLangHref('ar') %>" class="<%= currentLang === 'ar' ? 'active' : '' %>" data-lang="ar">العربية</a>
                <a href="<%= buildLangHref('en') %>" class="<%= currentLang === 'en' ? 'active' : '' %>" data-lang="en">English</a>
                <a href="<%= buildLangHref('es') %>" class="<%= currentLang === 'es' ? 'active' : '' %>" data-lang="es">Español</a>
                <a href="<%= buildLangHref('fr') %>" class="<%= currentLang === 'fr' ? 'active' : '' %>" data-lang="fr">Français</a>
                <a href="<%= buildLangHref('zh') %>" class="<%= currentLang === 'zh' ? 'active' : '' %>" data-lang="zh">中文</a>
                <a href="<%= buildLangHref('hi') %>" class="<%= currentLang === 'hi' ? 'active' : '' %>" data-lang="hi">हिन्दी</a>
                <a href="<%= buildLangHref('pt') %>" class="<%= currentLang === 'pt' ? 'active' : '' %>" data-lang="pt">Português</a>
                <a href="<%= buildLangHref('ru') %>" class="<%= currentLang === 'ru' ? 'active' : '' %>" data-lang="ru">Русский</a>
                <a href="<%= buildLangHref('de') %>" class="<%= currentLang === 'de' ? 'active' : '' %>" data-lang="de">Deutsch</a>
                <a href="<%= buildLangHref('tr') %>" class="<%= currentLang === 'tr' ? 'active' : '' %>" data-lang="tr">Türkçe</a>
            </div>
        </div>
    </div>
</nav>
