<%
    const buildLangHref = (langCode) => (
        langCode === 'ar' ? currentUrl : `${currentUrl}?lang=${langCode}`
    );
%>
<nav class="navbar" role="navigation" aria-label="Main navigation">
    <div class="nav-container">
        
        <!-- Logo -->
        <a href="/" class="nav-brand" aria-label="<%= t.title %> - Home">
            <img src="/static/images/logo.svg" alt="<%= t.title %>" class="brand-logo" width="36" height="36">
        </a>

        <!-- Desktop Navigation -->
        <div class="nav-desktop">
            <ul class="nav-pills">
                <li class="nav-pill-item">
                    <a href="/" class="nav-pill <%= currentUrl === '/' ? 'is-active' : '' %>" <%= currentUrl === '/' ? 'aria-current="page"' : '' %>>
                        <svg class="pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                            <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                        <span><%= t.nav_home %></span>
                    </a>
                </li>
                <li class="nav-pill-item">
                    <a href="/about" class="nav-pill <%= currentUrl === '/about' ? 'is-active' : '' %>" <%= currentUrl === '/about' ? 'aria-current="page"' : '' %>>
                        <svg class="pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="16" x2="12" y2="12"/>
                            <line x1="12" y1="8" x2="12.01" y2="8"/>
                        </svg>
                        <span><%= t.nav_about || (currentLang === 'ar' ? 'من نحن' : 'About') %></span>
                    </a>
                </li>
                <li class="nav-pill-item">
                    <a href="/blog" class="nav-pill <%= currentUrl && currentUrl.startsWith('/blog') ? 'is-active' : '' %>" <%= currentUrl && currentUrl.startsWith('/blog') ? 'aria-current="page"' : '' %>>
                        <svg class="pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                        <span><%= t.nav_blog || 'Blog' %></span>
                    </a>
                </li>
                <li class="nav-pill-item">
                    <a href="/tools" class="nav-pill <%= currentUrl && currentUrl.startsWith('/tools') ? 'is-active' : '' %>" <%= currentUrl && currentUrl.startsWith('/tools') ? 'aria-current="page"' : '' %>>
                        <svg class="pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                        </svg>
                        <span><%= t.nav_tools || (currentLang === 'ar' ? 'أدوات' : 'Tools') %></span>
                        <span class="pill-badge">30</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- Right Side Actions -->
        <div class="nav-actions">
            <!-- Search Trigger -->
            <button class="action-btn search-trigger" id="searchTrigger" aria-label="Open search">
                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/>
                    <path d="m21 21-4.35-4.35"/>
                </svg>
            </button>

            <!-- Language Selector -->
            <div class="lang-selector">
                <button class="lang-trigger" id="langTrigger" aria-expanded="false" aria-label="Change language: <%= currentLang.toUpperCase() %>">
                    <span class="current-lang"><%= currentLang.toUpperCase() %></span>
                    <svg class="lang-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="lang-panel" id="langPanel" role="menu">
                    <% 
                    const languages = [
                        { code: 'ar', name: 'العربية', flag: '🇸🇦' },
                        { code: 'en', name: 'English', flag: '🇬🇧' },
                        { code: 'es', name: 'Español', flag: '🇪🇸' },
                        { code: 'fr', name: 'Français', flag: '🇫🇷' },
                        { code: 'zh', name: '中文', flag: '🇨🇳' },
                        { code: 'hi', name: 'हिन्दी', flag: '🇮🇳' },
                        { code: 'pt', name: 'Português', flag: '🇵🇹' },
                        { code: 'ru', name: 'Русский', flag: '🇷🇺' },
                        { code: 'de', name: 'Deutsch', flag: '🇩🇪' },
                        { code: 'tr', name: 'Türkçe', flag: '🇹🇷' }
                    ];
                    languages.forEach(function(lang) {
                    %>
                        <a href="<%= buildLangHref(lang.code) %>" 
                           class="lang-item <%= currentLang === lang.code ? 'is-active' : '' %>" 
                           data-lang="<%= lang.code %>" 
                           role="menuitem">
                            <span class="lang-flag" aria-hidden="true"><%= lang.flag %></span>
                            <span class="lang-label"><%= lang.name %></span>
                        </a>
                    <% }); %>
                </div>
            </div>

            <!-- Mobile Menu Toggle -->
            <button class="mobile-toggle" id="mobileToggle" aria-expanded="false" aria-label="Open menu" aria-controls="mobileMenu">
                <span class="toggle-bar"></span>
                <span class="toggle-bar"></span>
                <span class="toggle-bar"></span>
            </button>
        </div>

    </div>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Mobile navigation">
        <div class="mobile-menu-header">
            <span class="mobile-title"><%= currentLang === 'ar' ? 'القائمة' : 'Menu' %></span>
            <button class="mobile-close" id="mobileClose" aria-label="Close menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        
        <nav class="mobile-nav">
            <a href="/" class="mobile-link <%= currentUrl === '/' ? 'is-active' : '' %>">
                <span class="mobile-icon">⌂</span>
                <span><%= t.nav_home %></span>
            </a>
            <a href="/about" class="mobile-link <%= currentUrl === '/about' ? 'is-active' : '' %>">
                <span class="mobile-icon">ℹ</span>
                <span><%= t.nav_about || (currentLang === 'ar' ? 'من نحن' : 'About') %></span>
            </a>
            <a href="/blog" class="mobile-link <%= currentUrl && currentUrl.startsWith('/blog') ? 'is-active' : '' %>">
                <span class="mobile-icon">📝</span>
                <span><%= t.nav_blog || 'Blog' %></span>
            </a>
            <a href="/tools" class="mobile-link <%= currentUrl && currentUrl.startsWith('/tools') ? 'is-active' : '' %>">
                <span class="mobile-icon">🛠</span>
                <span><%= t.nav_tools || (currentLang === 'ar' ? 'أدوات' : 'Tools') %></span>
                <span class="mobile-badge">30</span>
            </a>
            <div class="mobile-divider"></div>
            <a href="/support" class="mobile-link <%= currentUrl === '/support' ? 'is-active' : '' %>">
                <span><%= t.nav_support %></span>
            </a>
            <a href="/terms" class="mobile-link <%= currentUrl === '/terms' ? 'is-active' : '' %>">
                <span><%= t.nav_terms %></span>
            </a>
            <a href="/privacy" class="mobile-link <%= currentUrl === '/privacy' ? 'is-active' : '' %>">
                <span><%= t.nav_privacy %></span>
            </a>
        </nav>

        <div class="mobile-lang">
            <span class="mobile-lang-label"><%= currentLang === 'ar' ? 'اللغة' : 'Language' %></span>
            <div class="mobile-lang-grid">
                <% languages.forEach(function(lang) { %>
                    <a href="<%= buildLangHref(lang.code) %>" 
                       class="mobile-lang-item <%= currentLang === lang.code ? 'is-active' : '' %>"
                       data-lang="<%= lang.code %>">
                        <span><%= lang.flag %></span>
                        <span><%= lang.code.toUpperCase() %></span>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>

    <!-- Overlay -->
    <div class="nav-overlay" id="navOverlay"></div>
</nav>

<script>
(function() {
    // Elements
    var mobileToggle = document.getElementById('mobileToggle');
    var mobileClose = document.getElementById('mobileClose');
    var mobileMenu = document.getElementById('mobileMenu');
    var navOverlay = document.getElementById('navOverlay');
    var langTrigger = document.getElementById('langTrigger');
    var langPanel = document.getElementById('langPanel');
    
    // Mobile menu functions
    function openMobileMenu() {
        mobileMenu.classList.add('is-open');
        navOverlay.classList.add('is-visible');
        mobileToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
    }
    
    function closeMobileMenu() {
        mobileMenu.classList.remove('is-open');
        navOverlay.classList.remove('is-visible');
        mobileToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
    }
    
    if (mobileToggle) {
        mobileToggle.addEventListener('click', openMobileMenu);
    }
    
    if (mobileClose) {
        mobileClose.addEventListener('click', closeMobileMenu);
    }
    
    if (navOverlay) {
        navOverlay.addEventListener('click', function() {
            closeMobileMenu();
            closeLangPanel();
        });
    }
    
    // Language panel functions
    function openLangPanel() {
        langPanel.classList.add('is-open');
        langTrigger.classList.add('is-active');
        langTrigger.setAttribute('aria-expanded', 'true');
    }
    
    function closeLangPanel() {
        langPanel.classList.remove('is-open');
        langTrigger.classList.remove('is-active');
        langTrigger.setAttribute('aria-expanded', 'false');
    }
    
    if (langTrigger && langPanel) {
        langTrigger.addEventListener('click', function(e) {
            e.stopPropagation();
            if (langPanel.classList.contains('is-open')) {
                closeLangPanel();
            } else {
                openLangPanel();
            }
        });
        
        // Close when clicking outside
        document.addEventListener('click', function(e) {
            if (!langTrigger.contains(e.target) && !langPanel.contains(e.target)) {
                closeLangPanel();
            }
        });
    }
    
    // Preserve query parameters when switching language
    if (langPanel) {
        var langLinks = langPanel.querySelectorAll('.lang-item');
        langLinks.forEach(function(link) {
            link.addEventListener('click', function(e) {
                var lang = this.getAttribute('data-lang');
                var url = new URL(window.location.href);
                if (lang === 'ar') {
                    url.searchParams.delete('lang');
                } else {
                    url.searchParams.set('lang', lang);
                }
                this.href = url.toString();
            });
        });
    }
    
    // Mobile language items
    var mobileLangItems = document.querySelectorAll('.mobile-lang-item');
    mobileLangItems.forEach(function(item) {
        item.addEventListener('click', function(e) {
            var lang = this.getAttribute('data-lang');
            var url = new URL(window.location.href);
            if (lang === 'ar') {
                url.searchParams.delete('lang');
            } else {
                url.searchParams.set('lang', lang);
            }
            this.href = url.toString();
        });
    });
    
    // Escape key handling
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeMobileMenu();
            closeLangPanel();
        }
    });
    
    // Reset on resize to desktop
    window.addEventListener('resize', function() {
        if (window.innerWidth > 768) {
            closeMobileMenu();
        }
    });
})();
</script>
