<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= dir %>">
<%- include('partials/head', { pageTitle, description }) %>
<body class="about-page">
    <%- include('partials/navbar') %>

    <main class="container">
        <article class="about-layout">
            
            <!-- Hero Section -->
            <header class="about-hero animate-on-scroll">
                <p class="about-kicker"><%= currentLang === 'ar' ? 'صفحة تعريف' : 'About Page' %></p>
                <h1><%= about.title %></h1>
                <p class="about-intro"><%= about.intro %></p>
                <p class="about-summary"><%= about.summary %></p>
            </header>

            <!-- Mission & Story Split -->
            <section class="about-split stagger-children" aria-label="Mission and Story">
                <div class="about-panel">
                    <h2><%= about.missionTitle %></h2>
                    <p><%= about.missionText %></p>
                </div>
                <div class="about-panel">
                    <h2><%= about.storyTitle %></h2>
                    <p><%= about.storyText %></p>
                </div>
            </section>

            <!-- Pillars Section -->
            <section class="about-pillar-section" aria-labelledby="pillars-title">
                <h2 id="pillars-title" class="animate-on-scroll"><%= about.pillarsTitle %></h2>
                <div class="about-pillars stagger-children">
                    <% about.pillars.forEach(function(pillar) { %>
                        <article class="about-pillar-card">
                            <h3><%= pillar.title %></h3>
                            <p><%= pillar.text %></p>
                        </article>
                    <% }) %>
                </div>
            </section>

            <!-- Audience Section -->
            <section class="about-audience" aria-labelledby="audience-title">
                <div class="about-audience-copy animate-on-scroll">
                    <h2 id="audience-title"><%= about.audienceTitle %></h2>
                    <p><%= about.audienceText %></p>
                </div>
                <div class="about-stats stagger-children">
                    <% about.stats.forEach(function(stat) { %>
                        <div class="about-stat">
                            <strong><%= stat.value %></strong>
                            <span><%= stat.label %></span>
                        </div>
                    <% }) %>
                </div>
            </section>

            <!-- Proof Section -->
            <section class="about-proof" aria-labelledby="proof-title">
                <h2 id="proof-title" class="animate-on-scroll"><%= about.proofTitle %></h2>
                <div class="about-proof-grid stagger-children">
                    <% about.proofCards.forEach(function(card) { %>
                        <article class="about-proof-card">
                            <h3><%= card.title %></h3>
                            <p><%= card.text %></p>
                        </article>
                    <% }) %>
                </div>
            </section>

            <!-- Quotes Section -->
            <section class="about-quotes" aria-labelledby="quotes-title">
                <h2 id="quotes-title" class="animate-on-scroll"><%= about.quotesTitle %></h2>
                <div class="about-quote-grid stagger-children">
                    <% about.quotes.forEach(function(quote) { %>
                        <blockquote class="about-quote-card">
                            <p><%= quote %></p>
                        </blockquote>
                    <% }) %>
                </div>
            </section>

            <!-- CTA Section -->
            <section class="about-cta animate-on-scroll" aria-labelledby="cta-title">
                <h2 id="cta-title"><%= about.ctaTitle %></h2>
                <p><%= about.ctaText %></p>
                <div class="about-cta-actions">
                    <a href="/" class="cta-button"><%= about.ctaPrimary %></a>
                    <a href="/tools" class="about-secondary-link"><%= about.ctaSecondary %></a>
                </div>
            </section>

        </article>
    </main>

    <%- include('partials/footer') %>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Scroll animation observer
            var animatedElements = document.querySelectorAll('.animate-on-scroll, .stagger-children');
            
            if ('IntersectionObserver' in window) {
                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('visible');
                            observer.unobserve(entry.target);
                        }
                    });
                }, {
                    threshold: 0.1,
                    rootMargin: '0px 0px -50px 0px'
                });
                
                animatedElements.forEach(function(el) {
                    observer.observe(el);
                });
            } else {
                // Fallback for browsers without IntersectionObserver
                animatedElements.forEach(function(el) {
                    el.classList.add('visible');
                });
            }
        });
    </script>
</body>
</html>
