<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="rtl">
<%- include('partials/head', { pageTitle: article.title, description: article.excerpt }) %>
<body class="article-page">
    <%- include('partials/navbar') %>

    <main class="main-content">
        <div class="container">
            <article class="single-article">
                
                <header class="article-header">
                    <a href="/blog" class="back-link">
                        <%= t.back_to_blog || 'Back to Blog' %>
                    </a>
                    <h1 class="article-title"><%= article.title %></h1>
                    <div class="article-meta">
                        <time datetime="<%= article.date %>">
                            <i class="far fa-calendar-alt" aria-hidden="true"></i> 
                            <%= article.date %>
                        </time>
                    </div>
                </header>
                
                <div class="article-body">
                    <%- article.content %>
                </div>

                <%- include('partials/affiliate-offers', { affiliateContext: 'blog' }) %>

                <footer class="article-footer">
                    <a href="/" class="cta-button">
                        <%= t.start_browsing || 'Start Browsing Now' %>
                    </a>
                </footer>

            </article>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
